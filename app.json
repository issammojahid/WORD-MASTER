{
  "expo": {
    "name": "حروف المغرب",
    "slug": "huroof-al-maghrib",
    "version": "2.7.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "huroofalmaghrib",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.huroofalmaghrib",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "نحتاج إذنك لإرسال إشعارات حول دعوات الأصدقاء والمهام اليومية والمكافآت"
      }
    },
    "android": {
      "package": "com.huroofalmaghrib",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#0D1B2A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-av",
      "react-native-purchases",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0D1B2A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "f1e0f4f2-8408-4fe9-b300-c8d8fb573b4d"
      }
    }
  }
}
